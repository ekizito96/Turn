use "std/print";

struct MarketData {
    price: Num,
    volatility: Num,
    pe_ratio: Num,
    market_cap: Num
};

let fetch_market_data = tool turn(ticker: Str) -> MarketData {
    let d1 = infer MarketData { "{ \"price\": 850.50, \"volatility\": 0.45, \"pe_ratio\": 75.2, \"market_cap\": 2100000000000.0 }"; };
    return d1;
};

let analysis = infer Str with [fetch_market_data] {
    "You are the Fundamental Analyst. Fetch the market data for NVDA. Write a 2-sentence thesis.";
};

call("echo", "ANALYSIS OUTPUT:");
call("echo", analysis);
