// ============================================================================
// Turn Example: Object-Capability (OCap) Security Model
// 
// Demonstrates how Turn prevents guest-code and LLM hallucinations
// from leaking sensitive API keys to the network or logs.
// ============================================================================

struct Cap { id: Num };

// 1. Defining a Secure Tool
// The `secret` modifier strips `api_key` from the LLM-visible JSON Schema.
// The LLM can call stripe_charge but it NEVER sees the key.
let stripe_charge = tool turn(
    customer_name: Str,
    amount: Num,
    secret api_key: Cap
) -> Bool {
    call("echo", "[Stripe Tool] Charging $" + amount + " for " + customer_name);
    
    // api_key is an opaque Cap — cannot be echoed, logged, or serialized.
    // Turn VM raises PrivilegeViolationTrap if script code tries to leak it.
    
    call("echo", "[Stripe Tool] CHARGE SUCCESSFUL for " + customer_name);
    return true;
};

call("echo", "Booting Secure E-Commerce Agent...");

// 2. Mock injected capability (in production: injected by Rust Host Runtime from ENV)
// The Turn 'secret' injector looks for a local variable matching the param name.
let api_key = Cap { id: 1 };

// 3. Execution — The agent orchestrates the actual charge.
// The key is injected transparently by the host runtime; the guest logic never serializes it.
let result = stripe_charge("Alice", 150, api_key);

call("echo", "Receipt — success=" + result);
call("echo", "OCap security preserved: api_key was never exposed as a raw string.");
