{
  "openapi": "3.0.3",
  "info": {
    "title": "GitHub PR Review API",
    "version": "1.0.0",
    "description": "Subset of the GitHub REST API for managing and reviewing Pull Requests"
  },
  "servers": [
    {
      "url": "https://api.github.com"
    }
  ],
  "paths": {
    "/repos/{owner}/{repo}/pulls/{pull_number}": {
      "get": {
        "operationId": "get_pull_request",
        "description": "Get a pull request by number to read its title, body, and status.",
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Pull Request metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "title": { "type": "string" },
                    "body": { "type": "string" },
                    "state": { "type": "string" },
                    "url": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/repos/{owner}/{repo}/pulls/{pull_number}/files": {
      "get": {
        "operationId": "get_pull_request_files",
        "description": "List all explicitly modified files (additions, deletions, renames) in a pull request diff payload.",
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 30 }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of modified files and their unified diff patch.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "filename": { "type": "string" },
                      "status": { "type": "string" },
                      "additions": { "type": "integer" },
                      "deletions": { "type": "integer" },
                      "patch": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
