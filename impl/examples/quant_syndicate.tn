// ============================================================================
// Turn Language: The Algorithmic Trading Syndicate
// ============================================================================
//
// A highly concurrent, multi-agent quantitative hedge fund simulated in Turn.
// Three autonomous agents (Technical, Sentiment, Risk) debate an asset and 
// emit strongly-typed JSON structs synthesizing live market data. 
// The Chairman executes the final stochastic algorithmic trade.
//
// Powered by: Azure OpenAI (gpt-5.2-chat)
// Memory: Turn Native HNSW Vector Semantic Auto-Recall
// Concurrency: Turn Erlang-inspired Actor Model
// ============================================================================

// ── Persistent Market Epoch ───────────────────────────────────────────────────
persist let trade_epoch = 0;
persist let trade_epoch = trade_epoch + 1;

call("echo", "╔══════════════════════════════════════════════════════════╗");
call("echo", " DEEP-ASTEROID QUANT SYNDICATE — Market Epoch #" + trade_epoch);
call("echo", "╚══════════════════════════════════════════════════════════╝");

// ── Struct Definitions ────────────────────────────────────────────────────────

struct MarketContext {
    asset: Str,
    current_price: Num,
    volume_24h: Num,
    volatility_index: Str 
};

struct AgentReport {
    analyst_role: Str,
    action: Str,      // BUY, SELL, HOLD
    conviction: Num,  // 0 - 100
    rationale: Str
};

struct TradeExecution {
    epoch: Num,
    asset: Str,
    final_action: Str,
    allocation_pct: Num,
    stop_loss: Num,
    take_profit: Num,
    thesis: Str
};

// ── Tools: Live Data Ingestion ────────────────────────────────────────────────

// 1. Technical Analysis Tool
let get_market_data = tool turn(asset: Str) -> MarketContext {
    call("echo", "[Data Feed] Pulling live orderbook data for " + asset + "...");
    
    // Live real-world fetch — no mocks, zero auth required.
    let price_raw = call("http_get", "https://api.binance.com/api/v3/ticker/24hr?symbol=" + asset);
    let pd = call("json_parse", price_raw);
    
    let price_usd = pd["lastPrice"];
    
    // Feed the context to the VM's short term context window
    context.append("Live Market Data " + asset + ": Price USD " + price_usd);

    return infer MarketContext {
        "Parse the following raw API price data for " + asset + ". 
         Price USD: " + price_usd + "
         Estimate the volatility index as HIGH, MEDIUM, or LOW.";
    };
};

// 2. Sentiment Tool
let get_sentiment = tool turn(asset: Str) -> Str {
    call("echo", "[Social Feed] Scraping live sentiment for " + asset + "...");
    
    // E.g. pulling Top HackerNews posts mentioning crypto/asset
    // For safety without an API key we'll simulate the social digest response
    let digest = "Regulators crack down on illicit exchanges resulting in fear, but institutional ETF inflows remain strictly bullish.";
    context.append("Social sentiment digest: " + digest);
    return digest;
};

// ── Analysts (Actors) ─────────────────────────────────────────────────────────

let technical_analyst = tool turn(mc: MarketContext) -> AgentReport {
    call("echo", "[Technical Analyst] Calculating moving averages and momentum...");
    return infer AgentReport {
        "You are the Lead Technical Analyst for a quantitative hedge fund. 
         Analyze the asset: " + mc.asset + " at price $" + mc.current_price + ". 
         Volatility is " + mc.volatility_index + ".
         
         Output a technical report determining if we should BUY, SELL, or HOLD.
         Include conviction score (0-100) and a 2-sentence rationale based purely on price action.";
    } ~ 0.8 else {
        infer AgentReport { "Fallback: HOLD, conviction 50, insufficient quantitative convergence."; };
    };
};

let sentiment_analyst = tool turn(asset: Str, digest: Str) -> AgentReport {
    call("echo", "[Sentiment Analyst] Running NLP across market news...");
    return infer AgentReport {
        "You are the Lead Sentiment Analyst for a hedge fund evaluating: " + asset + ".
         
         Live Social Digest: " + digest + "
         
         Output a sentiment report determining if we should BUY, SELL, or HOLD based on fear/greed.
         Include conviction score (0-100) and a 1-sentence behavioral economics rationale.";
    };
};

let risk_manager = tool turn(asset: Str, prior_history: Str) -> AgentReport {
    call("echo", "[Risk Manager] Evaluating historical drawdowns and portfolio exposure...");
    return infer AgentReport {
        "You are the Chief Risk Officer evaluating: " + asset + ".
         
         Prior Fund History for this asset: " + prior_history + "
         
         If we lost money recently, you MUST enforce a HOLD or SELL. 
         Provide a strict risk-adjusted conviction score and 1-sentence rationale.";
    };
};

// ── Portfolio Manager (Chairman Orchestrator) ─────────────────────────────────

let portfolio_manager = tool turn(target_asset: Str) -> TradeExecution {
    call("echo", "\n[Portfolio Manager] Initializing Trade Epoch for " + target_asset);

    // 1. Memory: Recall our fund's past performance trading this asset via Semantic Vector DB
    let history = recall("trade history deep-asteroid fund " + target_asset);
    context.append("Historical Fund Exposure Context: " + history);

    // 2. Data: Fetch live feeds
    let market_ctx = get_market_data(target_asset);
    let sentiment_digest = get_sentiment(target_asset);

    // 3. Concurrency: Spawn all three analyst nodes as isolated linked actors
    call("echo", "\n[Portfolio Manager] Spawning analyst cluster concurrently...");
    let tech_pid = spawn linked turn() { return technical_analyst(market_ctx); };
    let sent_pid = spawn linked turn() { return sentiment_analyst(target_asset, sentiment_digest); };
    let risk_pid = spawn linked turn() { return risk_manager(target_asset, history); };

    // 4. Synchronization: Await reports
    let tech_report = harvest;
    let sent_report = harvest;
    let risk_report = harvest;

    // Load into reasoning context
    context.append("Tech Analyst: " + tech_report.action + " (Conviction: " + tech_report.conviction + ") - " + tech_report.rationale);
    context.append("Sent Analyst: " + sent_report.action + " (Conviction: " + sent_report.conviction + ") - " + sent_report.rationale);
    context.append("Risk Officer: " + risk_report.action + " (Conviction: " + risk_report.conviction + ") - " + risk_report.rationale);

    call("echo", "\n[Portfolio Manager] Consolidating models. Executing algorithm...");

    // 5. Compute: Final Stochastic Execution strictly bound to a token limit
    let trade = with budget(tokens: 1500, time: 60) {
        infer TradeExecution {
            "You are the algorithmic Portfolio Manager. Synthesize the 3 agent reports 
             in your context window for " + target_asset + ". 
             
             If Risk Officer says SELL, final_action MUST be SELL.
             Otherwise, calculate weighted average conviction. > 70 = BUY, < 30 = SELL, else HOLD.
             
             Designate allocation_pct (0.0 to 1.0), strict stop_loss price, and take_profit price.
             epoch: " + trade_epoch + "
             Write a 2-sentence executive thesis.";
        };
    };

    // 6. Persistence: Write trade receipt to disk and commit to vector memory
    call("fs_write", {"path": ".turn_store/trades/epoch_" + trade_epoch + "_" + target_asset + ".json", "content": call("json_stringify", trade)});
    remember("trade history deep-asteroid fund " + target_asset, "Epoch " + trade_epoch + " Action: " + trade.final_action + " Allocation: " + trade.allocation_pct + " Thesis: " + trade.thesis);

    return trade;
};

// ── Execution Entrypoint ──────────────────────────────────────────────────────

let ticker = "BTCUSDT";
let execution = portfolio_manager(ticker);

call("echo", "\n╔══════════════════════════════════════════════════════════╗");
call("echo", " TRADE EXECUTED — " + execution.asset + " (Epoch " + execution.epoch + ")");
call("echo", "╚══════════════════════════════════════════════════════════╝");
call("echo", "Action:       " + execution.final_action);
call("echo", "Allocation:   " + (execution.allocation_pct * 100) + "%");
call("echo", "Stop Loss:   $" + execution.stop_loss);
call("echo", "Take Profit: $" + execution.take_profit);
call("echo", "");
call("echo", "Thesis: " + execution.thesis);
call("echo", "Archived to Vector DB and Local FS (.turn_store/trades/)");

// Return explicitly for the VM runner to await resolution and print to stdout
return execution;
