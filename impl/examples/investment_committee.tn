// ============================================================================
// Turn Language: Investment Committee
// ============================================================================
//
// Three specialist agents — Fundamental Analyst, Risk Officer, Compliance
// Counsel — evaluate a live NVDA equity position for a $10M portfolio.
// The Committee Chair orchestrates concurrently and writes the final decision.
//
// Real APIs (no key required):
//   Yahoo Finance: https://query1.finance.yahoo.com
//
// Run:
//   export TURN_INFER_PROVIDER=~/.turn/providers/turn_provider_openai.wasm
//   export OPENAI_API_KEY=sk-...
//   turn run impl/examples/investment_committee.tn --id committee
// ============================================================================

// ── Persistent session counter ────────────────────────────────────────────────
persist let session = 0;
persist let session = session + 1;

call("echo", "=== INVESTMENT COMMITTEE — Session #" + session + " ===");
call("echo", "Mandate: Core Equity | AUM: $10M | Max position: 15% = $1.5M");

// ── Type definitions ─────────────────────────────────────────────────────────

struct MarketSnapshot {
    ticker:       Str,
    price:        Num,
    currency:     Str,
    market_cap_b: Num,
    pe_ratio:     Num,
    high_52w:     Num,
    low_52w:      Num
};

struct FundamentalThesis {
    ticker:           Str,
    thesis:           Str,
    valuation_signal: Str,
    conviction:       Num
};

struct RiskVerdict {
    ticker:         Str,
    requested_usd:  Num,
    max_allowed:    Num,
    breach:         Bool,
    approved_usd:   Num,
    risk_note:      Str
};

struct CommitteeMemo {
    ticker:     Str,
    decision:   Str,
    approved:   Num,
    conviction: Num,
    summary:    Str,
    flags:      Str
};

// ── Tool: Live market data ────────────────────────────────────────────────────
// Yahoo Finance public endpoints — zero auth required.

let fetch_market_data = tool turn(ticker: Str) -> MarketSnapshot {
    call("echo", "[DataFeed] Fetching " + ticker + " from Yahoo Finance...");

    let chart_raw   = call("http_get", "https://query1.finance.yahoo.com/v8/finance/chart/" + ticker + "?interval=1d&range=1d");
    let summary_raw = call("http_get", "https://query1.finance.yahoo.com/v10/finance/quoteSummary/" + ticker + "?modules=summaryDetail,defaultKeyStatistics,price");

    // Append raw feed to the context window so all agents share it
    context.append("Yahoo Finance feed for " + ticker + ": " + chart_raw);

    // LLM structures the raw JSON into typed fields
    let snap = infer MarketSnapshot {
        "Parse Yahoo Finance API responses. Populate all fields for ticker: " + ticker + "
         Fields: ticker (Str), price (regularMarketPrice as Num), currency (Str),
         market_cap_b (marketCap / 1e9 as Num), pe_ratio (trailingPE as Num),
         high_52w (fiftyTwoWeekHigh as Num), low_52w (fiftyTwoWeekLow as Num).
         Return 0 for any missing numeric field.
         
         Chart: " + chart_raw + "
         Summary: " + summary_raw;
    };

    call("echo", "[DataFeed] " + snap.ticker + " @ " + snap.price + " " + snap.currency + " | PE: " + snap.pe_ratio);
    return snap;
};

// ── Agent: Fundamental Analyst ────────────────────────────────────────────────

let fundamental_analyst = tool turn(snap: MarketSnapshot) -> FundamentalThesis {
    call("echo", "[Analyst] Fundamental analysis on " + snap.ticker);

    // Pull institutional memory before forming a view
    let prior = recall("investment memo " + snap.ticker);
    context.append("Prior institutional notes on " + snap.ticker + ": " + prior);

    // Confidence-gated: reject thesis below 70% confidence; fall back to cautious note
    let thesis = infer FundamentalThesis {
        "You are a senior equity analyst. Write a thesis for " + snap.ticker + "

         LIVE DATA:
         Price " + snap.price + " " + snap.currency + " | PE " + snap.pe_ratio +
         " | Cap $" + snap.market_cap_b + "B | 52W " + snap.low_52w + "-" + snap.high_52w + "

         HISTORICAL CONTEXT: " + prior + "

         Write 2-sentence thesis covering: valuation vs peers, business quality.
         valuation_signal: CHEAP, FAIR, or EXPENSIVE.
         conviction: 1 (very low) to 10 (very high).
         ticker: " + snap.ticker;
    } ~ 0.7 else {
        infer FundamentalThesis {
            "Conservative fallback thesis for " + snap.ticker + " due to low confidence.
             ticker: " + snap.ticker + ", valuation_signal: FAIR, conviction: 4,
             thesis: Limited data confidence — applying conservative stance.";
        };
    };

    call("echo", "[Analyst] Signal: " + thesis.valuation_signal + " | Conviction: " + thesis.conviction + "/10");

    // Store thesis in semantic memory for future sessions
    remember("investment memo " + snap.ticker, "Thesis: " + thesis.thesis + " | Conviction: " + thesis.conviction);

    return thesis;
};

// ── Agent: Risk Officer ───────────────────────────────────────────────────────

let risk_officer = tool turn(ticker: Str, requested: Num, snap: MarketSnapshot) -> RiskVerdict {
    call("echo", "[Risk] Compliance check — $" + requested + " into " + ticker);

    let max_allowed = 10000000.0 * 0.15;

    let verdict = with budget(tokens: 600, time: 20) {
        infer RiskVerdict {
            "You are the Chief Risk Officer of a $10M equity fund.
             Max single-stock position: $" + max_allowed + " (15% AUM).

             Trade: " + ticker + " | Requested: $" + requested + " | Max: $" + max_allowed + "
             Price: " + snap.price + " | 52W range: " + snap.low_52w + "-" + snap.high_52w + "

             Set breach = true if requested > max allowed.
             Set approved_usd = min(requested, max_allowed).
             Write 1-sentence risk_note on concentration.
             ticker: " + ticker + ", requested_usd: " + requested + ", max_allowed: " + max_allowed;
        };
    };

    call("echo", "[Risk] Breach: " + verdict.breach + " | Approved: $" + verdict.approved_usd);
    return verdict;
};

// ── Orchestrator: Committee Chair ─────────────────────────────────────────────

let committee_chair = tool turn(ticker: Str, requested: Num) -> CommitteeMemo {
    call("echo", "\n[Chair] Opening review — " + ticker + " ($" + requested + " requested)");

    // Step 1: Fetch live data (synchronous — both agents need it)
    let snap = fetch_market_data(ticker);

    // Step 2: Analyst and Risk Officer run concurrently as linked actors
    let analyst_pid = spawn linked turn() { return fundamental_analyst(snap); };
    let risk_pid    = spawn linked turn() { return risk_officer([ticker, requested, snap]); };

    // Attach Glass VM tracer to analyst — observe every infer call and tool invocation
    let _ = trace(analyst_pid);

    // Step 3: Collect both results (non-blocking, concurrent)
    let thesis = harvest;
    let risk   = harvest;

    // Step 4: Retrieve committee history and enrich chair's context
    let history = recall("committee history " + ticker);
    context.append("Risk note: " + risk.risk_note);
    context.append("History: " + history);

    call("echo", "[Chair] All reports in. Deliberating...");

    // Step 5: Chair decides with a hard token+time budget
    let memo = with budget(tokens: 1000, time: 30) {
        infer CommitteeMemo {
            "You are the Investment Committee Chair. Issue a binding decision.

             TICKER: " + ticker + " | Session: " + session + "
             Price: " + snap.price + " " + snap.currency + " | PE: " + snap.pe_ratio + " | Cap: $" + snap.market_cap_b + "B

             FUNDAMENTAL THESIS:
             " + thesis.thesis + "
             Signal: " + thesis.valuation_signal + " | Conviction: " + thesis.conviction + "/10

             RISK VERDICT:
             Breach: " + risk.breach + " | Approved: $" + risk.approved_usd + "
             " + risk.risk_note + "

             RULES:
             - If breach is true  → decision = REDUCE, approved = risk.approved_usd
             - If conviction < 6  → decision = REJECT
             - Otherwise          → decision = APPROVE

             Write a 2-sentence summary. List top risk flags.
             ticker: " + ticker;
        };
    };

    // Step 6: Write memo to disk for audit trail
    let memo_json = call("json_stringify", memo);
    call("fs_write", {"path": ".turn_store/memos/session_" + session + "_" + ticker + ".json", "content": memo_json});

    // Step 7: Store decision in semantic memory for future sessions
    remember("committee history " + ticker, "Session " + session + ": " + memo.decision + " at $" + memo.approved + " conviction " + memo.conviction + "/10");

    return memo;
};

// ── Pre-load institutional memory ─────────────────────────────────────────────

remember("investment memo NVDA", "Q1 2024: volatile post export restriction. Reduced to $800k. Regulatory tail risk ongoing.");
remember("committee history NVDA", "Session 3: REDUCE — mandate breach. Approved $800k. Monitor AI chip regulation.");

// ── Main ──────────────────────────────────────────────────────────────────────

let memo = committee_chair("NVDA", 2000000.0);

call("echo", "\n=== COMMITTEE DECISION ===");
call("echo", "Ticker:    " + memo.ticker);
call("echo", "Decision:  " + memo.decision);
call("echo", "Approved:  $" + memo.approved);
call("echo", "Conviction:" + memo.conviction + "/10");
call("echo", "");
call("echo", memo.summary);
call("echo", "");
call("echo", "Flags: " + memo.flags);
