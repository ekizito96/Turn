let get_patient_data = tool turn(secret db_token: Str, patient_name: Str) -> Map {
    // This is a fake database lookup that uses the secret token.
    // The LLM will only see `patient_name: Str` in the OpenAI Schema!
    return { "name": patient_name, "token_used": db_token, "status": "healthy" };
};

let db_token = "super_secret_token_12345";

// We pass the Turn closure as a first-class tool!
// The VM transpiles the Closure's arguments into a JSON Schema on-the-fly.
let result = infer Map with [get_patient_data] {
    "Retrieve the medical record for Alice Smith.";
};
return result;
