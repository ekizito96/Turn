// schema_api.tn
// Demonstrates: use schema::openapi, compile-time API adapters
//
// Turn downloads the GitHub OpenAPI spec at startup and generates
// native closures for every endpoint — no SDK installation needed.

// This line runs at compile time: downloads the OpenAPI JSON,
// parses it, and makes every endpoint a callable Turn function.
let github = use schema::openapi("https://raw.githubusercontent.com/github/rest-api-description/main/descriptions/api.github.com/api.github.com.json");

// Define what we want the LLM to return
struct RepoSummary {
    name: Str,
    description: Str,
    stars: Num,
    interesting_fact: Str,
}

// The LLM can call github functions as native tools
let result = infer RepoSummary with [github] {
    "Find the most interesting repository owned by the user 'ekizito96'
     and write a one-sentence summary explaining why it is interesting.";
};

call("echo", "Top repo: " + result.name);
call("echo", result.description);
call("echo", "Stars: " + result.stars);
call("echo", result.interesting_fact);
