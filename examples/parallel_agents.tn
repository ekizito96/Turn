// ============================================================================
// Turn Language: Parallel Research Agents
// ============================================================================
//
// A coordinator kicks off two specialist agents — GitHub Analyst and Hacker
// News Analyst — that run concurrently as isolated actors. Both fetch live
// public APIs. The coordinator synthesises their findings into a typed
// intelligence brief, persists it across runs, and archives it to disk.
//
// Real APIs (no key required):
//   GitHub Search: https://api.github.com
//   Hacker News:   https://hacker-news.firebaseio.com
//
// Run:
//   export TURN_INFER_PROVIDER=~/.turn/providers/turn_provider_openai.wasm
//   export OPENAI_API_KEY=sk-...
//   turn run examples/parallel_agents.tn --id research
// ============================================================================

// ── Persistent sweep counter ──────────────────────────────────────────────────
persist let sweep = 0;
persist let sweep = sweep + 1;

call("echo", "╔══════════════════════════════════════════════╗");
call("echo", " PARALLEL RESEARCH AGENTS — Sweep #" + sweep);
call("echo", "╚══════════════════════════════════════════════╝");

// ── Types ─────────────────────────────────────────────────────────────────────

struct TrendingRepo {
    name:        Str,
    language:    Str,
    description: Str,
    stars:       Num,
    signal:      Str
};

struct NewsStory {
    title:     Str,
    score:     Num,
    sentiment: Str,
    domain:    Str
};

struct IntelBrief {
    sweep_id:   Num,
    top_theme:  Str,
    gh_signal:  Str,
    hn_signal:  Str,
    action:     Str,
    confidence: Num
};

// ── Agent: GitHub Analyst ─────────────────────────────────────────────────────

let github_analyst = tool turn(language: Str) -> TrendingRepo {
    call("echo", "[GitHub] Searching top " + language + " repos...");

    let raw = call("http_get", "https://api.github.com/search/repositories?q=language:" + language + "&sort=stars&order=desc&per_page=5");

    // Share the raw API response with the coordinator's context window
    context.append("GitHub search (" + language + "): " + raw);

    let repo = infer TrendingRepo {
        "You are a developer intelligence analyst scanning GitHub.

         Language: " + language + "
         GitHub Search API response (JSON): " + raw + "

         Pick the most interesting repo from the items array.
         name: full_name, language: language field (or '" + language + "' if null),
         description: description (or 'No description' if null),
         stars: stargazers_count as Num (not string),
         signal: VIRAL if stars >= 10000, GROWING if >= 1000, else STABLE";
    };

    call("echo", "[GitHub] " + repo.name + " — " + repo.stars + " stars (" + repo.signal + ")");

    // Store finding in semantic memory for next sweep
    remember("github " + language, repo.name + " | " + repo.stars + " stars | " + repo.description);

    return repo;
};

// ── Agent: HN Analyst ────────────────────────────────────────────────────────

let hn_analyst = tool turn(topic: Str) -> NewsStory {
    call("echo", "[HN] Pulling live top stories for: " + topic);

    let ids_raw = call("http_get", "https://hacker-news.firebaseio.com/v0/topstories.json");
    let ids     = call("json_parse", ids_raw);

    let s1 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[0] + ".json"));
    let s2 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[1] + ".json"));
    let s3 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[2] + ".json"));
    let s4 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[3] + ".json"));
    let s5 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[4] + ".json"));

    // Feed top stories into the shared context window
    context.append("HN top 5: " + s1["title"] + " | " + s2["title"] + " | " + s3["title"]);

    let story = infer NewsStory {
        "You are a developer trend analyst. Pick the most relevant story for: '" + topic + "'

         HN stories (real, live):
         1. " + s1["title"] + " (score: " + s1["score"] + ")
         2. " + s2["title"] + " (score: " + s2["score"] + ")
         3. " + s3["title"] + " (score: " + s3["score"] + ")
         4. " + s4["title"] + " (score: " + s4["score"] + ")
         5. " + s5["title"] + " (score: " + s5["score"] + ")

         title: the chosen headline,
         score: its HN score as Num,
         sentiment: POSITIVE, NEGATIVE, or NEUTRAL,
         domain: primary topic keyword";
    };

    call("echo", "[HN] " + story.title + " (score: " + story.score + ")");

    // Store in semantic memory
    remember("hn " + topic, story.title + " | score " + story.score + " | " + story.sentiment);

    return story;
};

// ── Coordinator ───────────────────────────────────────────────────────────────

let coordinator = tool turn(topic: Str, language: Str) -> IntelBrief {
    call("echo", "\n[Coordinator] Sweep " + sweep + " — " + topic + " | " + language);

    // Pull prior sweep results into context before dispatching agents
    let prior_gh = recall("github " + language);
    let prior_hn = recall("hn " + topic);
    context.append("Prior GitHub sweep: " + prior_gh);
    context.append("Prior HN sweep: " + prior_hn);

    // Spawn both analysts as concurrent isolated linked actors
    let gh_pid = spawn linked turn() { return github_analyst(language); };
    let hn_pid = spawn linked turn() { return hn_analyst(topic); };

    // Attach Glass VM tracer to GitHub analyst — observes every tool call
    let _ = trace(gh_pid);

    // Non-blocking collection — both ran simultaneously
    let repo  = harvest;
    let story = harvest;

    // Add final signals to coordinator's context
    context.append("GitHub: " + repo.name + " " + repo.stars + " stars");
    context.append("HN: " + story.title);

    call("echo", "\n[Coordinator] Both complete. Synthesising brief...");

    // Confidence-gated synthesis under a hard token budget
    let brief = with budget(tokens: 800, time: 25) {
        infer IntelBrief {
            "Synthesise real-time developer intelligence into an actionable brief.

             SWEEP: " + sweep + " | TOPIC: " + topic + " | LANGUAGE: " + language + "

             GITHUB SIGNAL:
             Repo: " + repo.name + " (" + repo.stars + " stars, " + repo.signal + ")
             Desc: " + repo.description + "

             HACKER NEWS SIGNAL:
             Headline: " + story.title + " (score: " + story.score + ", " + story.sentiment + ")

             PRIOR CONTEXT:
             GitHub: " + prior_gh + "
             HN: " + prior_hn + "

             sweep_id: " + sweep + "
             top_theme: 1 sentence on dominant developer narrative today
             gh_signal: why this repo matters (1 sentence)
             hn_signal: why this story matters (1 sentence)
             action: 1 concrete thing a developer should do this week
             confidence: 0-100";
        } ~ 0.72 else {
            infer IntelBrief {
                "Fallback brief — signals below confidence threshold.
                 sweep_id: " + sweep + ", confidence: 50,
                 top_theme: Insufficient signal strength for confident assessment.
                 gh_signal: N/A, hn_signal: N/A, action: Retry with stronger signal.";
            };
        };
    };

    // Write brief to disk
    let brief_json = call("json_stringify", brief);
    call("fs_write", {"path": ".turn_store/intel/sweep_" + sweep + ".json", "content": brief_json});

    // Store synthesis in semantic memory
    remember("intel " + topic, "Sweep " + sweep + ": " + brief.top_theme + " | Action: " + brief.action);

    return brief;
};

// ── Main ──────────────────────────────────────────────────────────────────────

let brief = coordinator("AI inference", "Rust");

call("echo", "\n╔══════════════════════════════════════════════╗");
call("echo", " INTELLIGENCE BRIEF — Sweep #" + brief.sweep_id);
call("echo", "╚══════════════════════════════════════════════╝");
call("echo", "Theme:      " + brief.top_theme);
call("echo", "GitHub:     " + brief.gh_signal);
call("echo", "HN:         " + brief.hn_signal);
call("echo", "Action:     " + brief.action);
call("echo", "Confidence: " + brief.confidence + "%");
call("echo", "Saved to:   .turn_store/intel/sweep_" + brief.sweep_id + ".json");
