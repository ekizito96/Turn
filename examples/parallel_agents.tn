// ============================================================================
// Turn Language Example: Parallel Research Agents
//
// Use Case: Multiple specialist agents work in parallel retrieving and
//           analysing real public data, then a coordinator synthesises
//           all their findings into a final intelligence brief.
//
// Agents in this example:
//   - A GitHub Trending Analyst  (fetches real trending repos from GitHub API)
//   - A Hacker News Analyst      (fetches live top stories from HN Firebase API)
//   - A Coordinator              (synthesises both into a ranked intelligence brief)
//
// APIs used (no keys required):
//   - GitHub Trending (via undocumented but stable public endpoint)
//   - Hacker News Firebase REST API (https://hacker-news.firebaseio.com)
//
// Run:
//   export TURN_INFER_PROVIDER=~/.turn/providers/turn_provider_openai.wasm
//   export OPENAI_API_KEY=sk-...
//   turn run examples/parallel_agents.tn
// ============================================================================

// ---- Typed Structs ---------------------------------------------------------

struct TrendingRepo {
    name: Str,
    language: Str,
    description: Str,
    stars: Str,
    trend_signal: Str     // "GROWING" | "VIRAL" | "STABLE"
};

struct NewsStory {
    title: Str,
    score: Str,
    sentiment: Str,       // "POSITIVE" | "NEGATIVE" | "NEUTRAL"
    relevance: Str        // domain/topic keyword
};

struct IntelBrief {
    top_theme: Str,
    github_highlight: Str,
    hn_highlight: Str,
    developer_action: Str,
    confidence: Num
};

// ---- GitHub Trending Analyst -----------------------------------------------
// Fetches the GitHub trending page and extracts the most interesting repo.

let github_analyst = tool turn(language: Str) -> TrendingRepo {
    call("echo", "[GitHub] Fetching trending repos for: " + language);

    // GitHub has a public trending API that doesn't require auth
    let url = "https://api.github.com/search/repositories?q=language:" + language + "&sort=stars&order=desc&per_page=3";
    let raw = call("http_get", url);

    let repo = infer TrendingRepo {
        "You are a developer intelligence analyst.
         Analyse this GitHub repositories search result and identify the most interesting project.
         
         Language filter: " + language + "
         
         API response:
         " + raw + "
         
         Extract the full_name as 'name', the programming_language as 'language',
         the description (or 'No description' if null), and the stargazers_count as 'stars'.
         Set trend_signal based on star count: >10k = VIRAL, >1k = GROWING, else STABLE.
         Return the single most interesting repository.";
    };

    call("echo", "[GitHub] Top repo: " + repo.name + " (" + repo.stars + " stars)");
    return repo;
};

// ---- Hacker News Analyst ---------------------------------------------------
// Fetches the top Hacker News story and rates its sentiment.

let hn_analyst = tool turn(topic: Str) -> NewsStory {
    call("echo", "[HN] Fetching top stories...");

    let ids_raw = call("http_get", "https://hacker-news.firebaseio.com/v0/topstories.json");
    let ids = call("json_parse", ids_raw);

    let s1 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[0] + ".json"));
    let s2 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[1] + ".json"));
    let s3 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[2] + ".json"));

    let story = infer NewsStory {
        "You are a developer sentiment analyst.
         Choose the most relevant story from the list below based on the topic: '" + topic + "'
         
         Story 1: " + s1["title"] + " (score: " + s1["score"] + ")
         Story 2: " + s2["title"] + " (score: " + s2["score"] + ")
         Story 3: " + s3["title"] + " (score: " + s3["score"] + ")
         
         Set title to the chosen story's title.
         Set score to its score as a string.
         Set sentiment to POSITIVE, NEGATIVE, or NEUTRAL based on the title.
         Set relevance to the primary domain/topic keyword.";
    };

    call("echo", "[HN] Top story: " + story.title);
    return story;
};

// ---- Coordinator Agent -----------------------------------------------------

let coordinator = tool turn(topic: Str, language: Str) -> IntelBrief {
    call("echo", "\n=== PARALLEL RESEARCH AGENTS ===");
    call("echo", "Topic: " + topic + " | Language: " + language);
    call("echo", "");

    // Spawn both analysts concurrently as isolated linked actors
    let github_pid = spawn linked turn() { return github_analyst(language); };
    let hn_pid     = spawn linked turn() { return hn_analyst(topic); };

    // Collect both concurrently (not sequentially)
    let repo  = harvest github_pid;
    let story = harvest hn_pid;

    call("echo", "\n[Coordinator] All data in. Synthesising brief...");

    let brief = infer IntelBrief {
        "You are a developer intelligence coordinator.
         Synthesise the following intelligence into a ranked brief for a senior engineer.
         
         Topic of investigation: " + topic + "
         
         GITHUB SIGNAL:
         Repo: " + repo.name + "
         Stars: " + repo.stars + " | Trend: " + repo.trend_signal + "
         Description: " + repo.description + "
         
         HACKER NEWS SIGNAL:
         Headline: " + story.title + "
         Score: " + story.score + " | Sentiment: " + story.sentiment + "
         
         Write:
         - top_theme: one sentence on what developers are most excited about right now
         - github_highlight: why this repo matters (1 sentence)
         - hn_highlight: why this story is relevant (1 sentence)
         - developer_action: one concrete thing a developer should do this week
         - confidence from 0 to 100 based on signal strength";
    };

    return brief;
};

// ---- Main ------------------------------------------------------------------

let brief = coordinator(["AI inference", "Rust"]);

call("echo", "\n=== INTELLIGENCE BRIEF ===");
call("echo", "Theme:           " + brief.top_theme);
call("echo", "GitHub Signal:   " + brief.github_highlight);
call("echo", "HN Signal:       " + brief.hn_highlight);
call("echo", "Action:          " + brief.developer_action);
call("echo", "Confidence:      " + brief.confidence + "%");
