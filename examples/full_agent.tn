// ============================================================================
// Turn Language: Full Research Agent
// ============================================================================
//
// A persistent autonomous research agent — the "kitchen sink" example.
// Demonstrates every Turn primitive working together in a real-world
// scenario: fetching live data from three public APIs, running three
// specialist agents concurrently, gating results by confidence, persisting
// state across restarts, archiving reports to disk, and maintaining a
// growing semantic memory of past research.
//
// Turn Primitives Demonstrated:
//   struct               — ResearchSource, ResearchReport
//   tool turn()          — typed reusable agent closures
//   persist let          — run counter and topic survive crashes/restarts
//   context.append       — accumulate cross-source intelligence
//   remember(key, val)   — store findings in HNSW semantic memory (key first)
//   recall(key)          — retrieve prior research before writing new report
//   spawn linked         — three specialists run as isolated concurrent actors
//   harvest              — non-blocking collection (bare expression, no args)
//   trace(pid)           — Glass VM telemetry on the GitHub agent
//   infer Type { } ~ N else { } — confidence gate with fallback
//   with budget(tokens:, time:) — hard cap on synthesis inference call
//   match expr { ok(v) -> {} err(e) -> {} } — monadic error handling
//   send pid, msg        — mailbox message dispatch
//   await receive        — blocking mailbox receive
//   fs_write             — report archived to disk (map literal, string keys)
//   http_get             — live network calls to three public APIs
//   json_parse           — parse API responses natively
//   json_stringify       — serialise struct to JSON for disk write
//   time_now             — Unix timestamp for report metadata
//
// Real APIs (no key required):
//   Hacker News: https://hacker-news.firebaseio.com
//   GitHub:      https://api.github.com
//   Wikipedia:   https://en.wikipedia.org/api/rest_v1
//
// Run:
//   export TURN_INFER_PROVIDER=~/.turn/providers/turn_provider_openai.wasm
//   export OPENAI_API_KEY=sk-...
//   turn run examples/full_agent.tn --id research_agent
// ============================================================================

// ── Persistent state — survives crashes and restarts ──────────────────────────
persist let run_id = 0;
persist let run_id = run_id + 1;

// Default research topic — can be overridden via message at runtime
persist let current_topic = "AI inference at the edge";

call("echo", "╔══════════════════════════════════════════════════════╗");
call("echo", " TURN RESEARCH AGENT — Run #" + run_id);
call("echo", " Topic: " + current_topic);
call("echo", "╚══════════════════════════════════════════════════════╝");

// ── Types ─────────────────────────────────────────────────────────────────────

struct ResearchSource {
    source:     Str,
    title:      Str,
    snippet:    Str,
    relevance:  Str
};

struct ResearchReport {
    run_id:      Num,
    topic:       Str,
    brief:       Str,
    sources:     Str,
    questions:   Str,
    next_steps:  Str,
    confidence:  Num,
    timestamp:   Num
};

// ── Agent: Hacker News source ─────────────────────────────────────────────────

let hn_source = tool turn(topic: Str) -> ResearchSource {
    call("echo", "[HN Agent] Fetching stories for: " + topic);

    let ids_raw = call("http_get", "https://hacker-news.firebaseio.com/v0/topstories.json");
    let ids     = call("json_parse", ids_raw);

    let s1 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[0] + ".json"));
    let s2 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[1] + ".json"));
    let s3 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[2] + ".json"));
    let s4 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[3] + ".json"));
    let s5 = call("json_parse", call("http_get", "https://hacker-news.firebaseio.com/v0/item/" + ids[4] + ".json"));

    context.append("HN live: " + s1["title"] + " | " + s2["title"] + " | " + s3["title"]);

    let article = infer ResearchSource {
        "Pick the most relevant HN story for the topic: '" + topic + "'

         Stories (real, live right now):
         1. " + s1["title"] + " (score: " + s1["score"] + ")
         2. " + s2["title"] + " (score: " + s2["score"] + ")
         3. " + s3["title"] + " (score: " + s3["score"] + ")
         4. " + s4["title"] + " (score: " + s4["score"] + ")
         5. " + s5["title"] + " (score: " + s5["score"] + ")

         source: HackerNews
         title: the chosen headline
         snippet: 1-sentence summary of what the story is about
         relevance: HIGH, MEDIUM, or LOW";
    };

    call("echo", "[HN Agent] Picked: " + article.title + " [" + article.relevance + "]");
    return article;
};

// ── Agent: GitHub source ──────────────────────────────────────────────────────

let github_source = tool turn(topic: Str) -> ResearchSource {
    call("echo", "[GitHub Agent] Searching repos for: " + topic);

    let raw = call("http_get", "https://api.github.com/search/repositories?q=" + topic + "&sort=stars&order=desc&per_page=3");

    context.append("GitHub search '" + topic + "': " + raw);

    let article = infer ResearchSource {
        "Pick the most relevant GitHub repo for the topic: '" + topic + "'

         GitHub Search API response: " + raw + "

         source: GitHub
         title: full_name of the repo
         snippet: 1 sentence combining description and star count
         relevance: HIGH if stars > 5000, MEDIUM if > 500, else LOW";
    };

    call("echo", "[GitHub Agent] Picked: " + article.title + " [" + article.relevance + "]");
    return article;
};

// ── Agent: Wikipedia source ───────────────────────────────────────────────────

let wiki_source = tool turn(topic: Str) -> ResearchSource {
    call("echo", "[Wikipedia Agent] Fetching summary...");

    let raw  = call("http_get", "https://en.wikipedia.org/api/rest_v1/page/summary/Artificial_intelligence");
    let wiki = call("json_parse", raw);

    context.append("Wikipedia on AI: " + wiki["extract"]);

    let article = infer ResearchSource {
        "Adapt the Wikipedia article to the research topic: '" + topic + "'

         Wikipedia title: " + wiki["title"] + "
         Wikipedia extract: " + wiki["extract"] + "

         source: Wikipedia
         title: " + wiki["title"] + "
         snippet: first 2 sentences of the extract
         relevance: HIGH";
    };

    call("echo", "[Wikipedia Agent] Extracted: " + article.title);
    return article;
};

// ── Research Coordinator ──────────────────────────────────────────────────────

let run_research = tool turn(topic: Str) -> ResearchReport {
    call("echo", "\n[Agent] Starting research on: " + topic);

    // Load prior research from semantic memory before dispatching agents
    let prior_hn     = recall("HN " + topic);
    let prior_gh     = recall("GitHub " + topic);
    let prior_report = recall("report " + topic);

    context.append("Prior HN research: " + prior_hn);
    context.append("Prior GitHub research: " + prior_gh);
    context.append("Prior report summary: " + prior_report);

    call("echo", "[Agent] Prior context loaded. Spawning specialist agents...");

    // Spawn all three agents as isolated concurrent linked actors
    let hn_pid   = spawn linked turn() { return hn_source(topic); };
    let gh_pid   = spawn linked turn() { return github_source(topic); };
    let wiki_pid = spawn linked turn() { return wiki_source(topic); };

    // Attach Glass VM tracer to the GitHub agent — log every tool call and infer
    let _ = trace(gh_pid);

    // Collect all three results concurrently (non-blocking, in spawn order)
    let hn_art   = harvest;
    let gh_art   = harvest;
    let wiki_art = harvest;

    // Accumulate all source signals into the coordinator's context window
    context.append("HN [" + hn_art.relevance + "]: " + hn_art.snippet);
    context.append("GitHub [" + gh_art.relevance + "]: " + gh_art.snippet);
    context.append("Wikipedia: " + wiki_art.snippet);

    call("echo", "\n[Agent] All sources in. Writing report...");

    // Capture current time for the report timestamp
    let ts = call("time_now", null);

    // Synthesise with confidence gate (>= 80%) and hard token+time budget
    let report = with budget(tokens: 1200, time: 45) {
        infer ResearchReport {
            "Produce a structured research report.

             RUN: " + run_id + " | TOPIC: " + topic + "

             LIVE SOURCES:
             [HackerNews]  " + hn_art.title + " — " + hn_art.snippet + " (" + hn_art.relevance + ")
             [GitHub]      " + gh_art.title + " — " + gh_art.snippet + " (" + gh_art.relevance + ")
             [Wikipedia]   " + wiki_art.title + " — " + wiki_art.snippet + "

             PRIOR RESEARCH (from past runs):
             " + prior_report + "

             run_id: " + run_id + "
             topic: " + topic + "
             brief: 3 sentences synthesising all sources
             sources: comma-separated list of the 3 source titles
             questions: 2 questions this research raised but couldn't answer
             next_steps: 2 concrete actions a researcher should take next
             confidence: 0-100 based on source quality and coverage
             timestamp: " + ts;
        } ~ 0.80 else {
            infer ResearchReport {
                "Fallback — confidence below threshold. Acknowledge limited signal.
                 run_id: " + run_id + ", topic: " + topic + ", confidence: 55,
                 brief: Signal quality insufficient for high-confidence synthesis.
                 sources: N/A, questions: N/A, next_steps: Retry with broader search terms.
                 timestamp: " + ts;
            };
        };
    };

    // Store findings in semantic memory for future runs
    remember("HN " + topic, hn_art.title + " | " + hn_art.snippet);
    remember("GitHub " + topic, gh_art.title + " | " + gh_art.snippet);
    remember("report " + topic, "Run " + run_id + ": " + report.brief);

    // Archive the full report to disk
    let json = call("json_stringify", report);
    call("fs_write", {"path": ".turn_store/reports/run_" + run_id + ".json", "content": json});

    return report;
};

// ── Main ──────────────────────────────────────────────────────────────────────
// The agent runs research on the persisted topic from the last session.
// To change the topic, send a new topic string to the process mailbox
// and it will update the persistent topic for all future runs.
//
// You can also send a new topic before the next run:
//   turn send <pid> "quantum computing hardware"

// Check mailbox non-blockingly for an updated topic
let incoming = receive;
if incoming != null {
    persist let current_topic = incoming;
    call("echo", "[Agent] Topic updated to: " + current_topic);
};

let report = run_research(current_topic);

call("echo", "\n╔══════════════════════════════════════════════════════╗");
call("echo", " RESEARCH REPORT — Run #" + report.run_id);
call("echo", "╚══════════════════════════════════════════════════════╝");
call("echo", "Topic:      " + report.topic);
call("echo", "Confidence: " + report.confidence + "%");
call("echo", "");
call("echo", report.brief);
call("echo", "");
call("echo", "Sources:    " + report.sources);
call("echo", "");
call("echo", "Open Questions:");
call("echo", report.questions);
call("echo", "");
call("echo", "Next Steps:");
call("echo", report.next_steps);
call("echo", "");
call("echo", "Archived to: .turn_store/reports/run_" + report.run_id + ".json");
