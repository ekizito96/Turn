// Weather agent: uses LLM (Azure OpenAI) with weather tool
// Run: cd impl && cargo run -- run --with-llm ../examples/turn-vs-python/weather_agent.tn
// Env: AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_API_KEY, AZURE_OPENAI_DEPLOYMENT

turn {
  let question = "What's the weather in San Francisco?";
  let answer = call("llm", question);
  return answer;
}
