// Turn: Task assistant - same logic as Python example
// Run: cd impl && cargo run -- run ../examples/turn-vs-python/turn_example.tn
// (uses echo as stub for get_weather; register get_weather for real use)

turn {
  let task = "Find weather in San Francisco";
  remember("task", task);
  context.append("Task: " + task);

  let weather = call("echo", "sunny");
  remember("weather", weather);
  context.append("Weather: " + weather);

  return weather;
}
