// wasm_compute.tn
// Demonstrates: use_wasm, Wasm Component FFI, sandboxed computation
//
// A Turn agent delegates heavy numerical computation to a Rust-compiled
// Wasm binary. If the Wasm module crashes, the Turn agent catches the
// error and continues running — the supervisor tree is unaffected.

// Mount the Wasm module as a map of callable Turn functions.
// The binary is sandboxed: it cannot access the network, filesystem,
// environment variables, or any Turn process state.
let math = use_wasm("./math_lib.wasm");

struct ComputeResult {
    input_a: Num,
    input_b: Num,
    sum: Num,
    difference: Num,
    analysis: Str,
}

// Call Wasm functions directly — they behave identically to Turn functions
let a = 128;
let b = 57;
let sum  = math.add(a, b);
let diff = math.sub(a, b);

call("echo", "Wasm computed sum:        " + sum);
call("echo", "Wasm computed difference: " + diff);

// The LLM can now reason over the Wasm output using typed inference
let result = infer ComputeResult {
    "An engineer computed two values using native Wasm arithmetic:
     Input A = " + a + ", Input B = " + b + "
     Sum = " + sum + ", Difference = " + diff + "
     Write a one-sentence analysis of what these numbers might represent
     in a financial risk context.";
};

call("echo", result.analysis);
return result;
